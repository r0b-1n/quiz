<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>QuizMaster 🎯</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎯</text></svg>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="style.css" />
</head>
<body>

  <!-- ── Dark Mode Toggle ───────────────────────────────────────── -->
  <button id="theme-toggle" onclick="toggleTheme()" aria-label="Toggle dark mode">🌙</button>

  <!-- ════════════════════════════════════════════════════════════
       START SCREEN
  ═════════════════════════════════════════════════════════════ -->
  <section id="start-screen" class="screen">
    <div class="start-hero">
      <span class="logo">🎯</span>
      <h1>QuizMaster</h1>
      <p>Challenge your knowledge across four exciting game modes</p>
    </div>

    <div class="mode-grid">

      <!-- Image Guess -->
      <div class="mode-card" onclick="selectMode('image')" tabindex="0"
           onkeydown="if(event.key==='Enter')selectMode('image')">
        <span class="icon">🖼️</span>
        <h3>Image Guess</h3>
        <p>Look at a photo and type what you see. Test your visual knowledge!</p>
        <span class="mode-badge">Type answer</span>
      </div>

      <!-- Four Images -->
      <div class="mode-card" onclick="selectMode('four_images')" tabindex="0"
           onkeydown="if(event.key==='Enter')selectMode('four_images')">
        <span class="icon">🔠</span>
        <h3>4 Images 1 Word</h3>
        <p>Four images share one connecting word. Can you guess it?</p>
        <span class="mode-badge">Word puzzle</span>
      </div>

      <!-- Multiple Choice -->
      <div class="mode-card" onclick="selectMode('multiple_choice')" tabindex="0"
           onkeydown="if(event.key==='Enter')selectMode('multiple_choice')">
        <span class="icon">🧠</span>
        <h3>Multiple Choice</h3>
        <p>Classic general-knowledge quiz with four options per question.</p>
        <span class="mode-badge">Pick one</span>
      </div>

      <!-- Speed Mode -->
      <div class="mode-card" onclick="selectMode('speed')" tabindex="0"
           onkeydown="if(event.key==='Enter')selectMode('speed')">
        <span class="icon">⚡</span>
        <h3>Speed Mode</h3>
        <p>60 seconds, mixed questions, auto-advance. How many can you get?</p>
        <span class="mode-badge">60 s rush</span>
      </div>

    </div>
  </section>

  <!-- ════════════════════════════════════════════════════════════
       QUIZ SCREEN
  ═════════════════════════════════════════════════════════════ -->
  <section id="quiz-screen" class="screen hidden">

    <!-- Header -->
    <header class="quiz-header">
      <button class="btn-back" onclick="goHome()">← Menu</button>

      <div class="header-stats">
        <!-- Score -->
        <div class="stat-chip score" id="header-score">⭐ 0</div>

        <!-- Streak -->
        <div class="stat-chip streak" id="header-streak">
          <span id="streak-fire" class="streak-fire">✨</span> 0
        </div>

        <!-- Speed timer (hidden unless speed mode) -->
        <div id="timer-wrap" class="hidden">
          <div class="timer-ring-wrap">
            <svg viewBox="0 0 48 48">
              <circle class="timer-ring-bg" cx="24" cy="24" r="22" />
              <circle id="timer-ring-fill" class="timer-ring-fill" cx="24" cy="24" r="22"
                style="stroke-dashoffset:0;" />
            </svg>
            <span id="timer-number" class="timer-number">60</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Progress -->
    <div class="progress-wrap">
      <div class="progress-label">
        <span id="progress-label">Question 1 of 1</span>
        <span id="progress-pct">0%</span>
      </div>
      <div class="progress-bar">
        <div id="progress-fill" class="progress-fill" style="width:0%"></div>
      </div>
    </div>

    <!-- Dynamic question area -->
    <div class="question-card">
      <div id="question-area"></div>
    </div>

  </section>

  <!-- ════════════════════════════════════════════════════════════
       RESULT SCREEN
  ═════════════════════════════════════════════════════════════ -->
  <section id="result-screen" class="screen hidden">
    <div class="result-card">
      <span id="result-emoji" class="result-emoji">🏆</span>
      <h2 id="result-title" class="result-title">Excellent!</h2>
      <p id="result-subtitle" class="result-subtitle">You answered 10 questions</p>

      <div class="result-stats">
        <div class="result-stat">
          <span id="res-score" class="stat-value">0</span>
          <span class="stat-label">Total Score</span>
        </div>
        <div class="result-stat">
          <span id="res-accuracy" class="stat-value">0%</span>
          <span class="stat-label">Accuracy</span>
        </div>
        <div class="result-stat">
          <span id="res-correct" class="stat-value">0/0</span>
          <span class="stat-label">Correct</span>
        </div>
        <div class="result-stat">
          <span id="res-streak" class="stat-value">0</span>
          <span class="stat-label">Best Streak 🔥</span>
        </div>
        <div class="result-stat" style="grid-column: 1/-1;">
          <span id="res-hints" class="stat-value">0</span>
          <span class="stat-label">Hints Used 💡</span>
        </div>
      </div>

      <div class="result-actions">
        <button class="btn btn-primary" onclick="restartQuiz()">🔄 Play Again</button>
        <button class="btn btn-outline" onclick="goHome()">🏠 Main Menu</button>
      </div>
    </div>
  </section>

  <!-- ── Scripts ─────────────────────────────────────────────── -->
  <script src="data.js"></script>
  <script src="script.js"></script>
</body>
</html>
